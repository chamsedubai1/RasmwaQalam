# =============================================================================
# Production environment template for Hostinger Cloud Hosting (Node.js App)
# Copy these into hPanel → Setup Node.js App → Environment Variables.
# Do NOT commit the real values.
# =============================================================================

# Required: runtime
NODE_ENV=production
PORT=                                    # leave blank — Hostinger Passenger injects this

# Required: database (Neon Postgres — free tier is fine)
# Get the pooled connection string from console.neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Required: cryptographic secrets (generate 32+ random bytes each, all distinct)
# Quick generator: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=
AUDIT_LOG_HMAC_SECRET=
DOWNLOAD_SIGNING_SECRET=

# Required: Ollama URL (self-hosted LLM).
# - Docker compose with an `ollama` service: http://ollama:11434
# - Native Ollama on the host: http://localhost:11434
# AI features fail closed (503) if Ollama is unreachable OR if the moderation
# model is not installed. This is intentional — student safety.
OLLAMA_URL=http://ollama:11434
OLLAMA_GENERATION_MODEL=qwen2.5:3b
OLLAMA_MODERATION_MODEL=llama-guard3:1b

# Optional: additional AI providers (fallback chain)
OPENAI_API_KEY=
HUGGING_FACE_API_KEY=
STABILITY_API_KEY=
QWEN_API_KEY=
QWEN_API_BASE=

# CORS — comma-separated list of allowed origins for your domain
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=

# Redis — NOT available on Hostinger Cloud Hosting. Leave blank.
# The app degrades gracefully to an in-process queue with concurrency cap 4
# and in-memory rate limiters. If you later move to a VPS, set REDIS_URL
# and the Bull queue + Redis-backed rate limiters activate automatically.
REDIS_URL=
